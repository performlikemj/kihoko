# Kihoko Portfolio - Environment Variables Example
# Copy this file to .env and fill in your actual values

# Azure Cosmos DB
COSMOS_DB_ENDPOINT=https://your-cosmos-db.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-db-primary-key-here

# Azure Storage Account
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=your-storage-key;EndpointSuffix=core.windows.net

# Stripe (online store payments)
# From https://dashboard.stripe.com/apikeys and Developers -> Webhooks.
# In production these must also be set as Azure Static Web App application settings.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret
# Public site URL for Stripe redirect URLs (set in production only, e.g.
# https://kihoko.com — leave unset for local development)
PUBLIC_SITE_URL=

# API Configuration
REACT_APP_API_URL=https://your-app.azurestaticapps.net/api
REACT_APP_DEV_API_URL=http://localhost:7071/api

# Frontend env variables are read by webpack via web/.env

# Instructions:
# 1. Copy this file: cp env.example .env
# 2. Fill in your actual Azure credentials
# 3. Or use the setup-env.sh script for local development 